rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: checkins
    // Document ID: {uid} (User's Google Auth UID)
    // Fields:
    //   - uid: string (required) - The user's UID
    //   - email: string (required) - The user's email
    //   - fullName: string (required, max 100 chars) - Student's full name
    //   - contactInfo: string (required, max 20 chars) - Contact info (Phone/Zalo)
    //   - timestamp: timestamp (required) - Time of check-in
    //   - latitude: number (optional) - Location latitude
    //   - longitude: number (optional) - Location longitude
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "phandu8899@gmail.com" && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isValidCheckIn(userId) {
      let allowedFields = ['uid', 'email', 'fullName', 'contactInfo', 'timestamp', 'latitude', 'longitude'];
      let requiredFields = ['uid', 'email', 'fullName', 'contactInfo', 'timestamp'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             request.resource.data.uid == userId &&
             request.resource.data.email == request.auth.token.email &&
             isValidString('fullName', 2, 100) &&
             isValidString('contactInfo', 8, 20) &&
             request.resource.data.timestamp is timestamp &&
             (!('latitude' in request.resource.data) || request.resource.data.latitude is number) &&
             (!('longitude' in request.resource.data) || request.resource.data.longitude is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /admins/{adminEmail} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
                    hasOnlyAllowedFields(['email', 'addedBy', 'timestamp']) &&
                    hasRequiredFields(['email', 'addedBy', 'timestamp']) &&
                    request.resource.data.email == adminEmail;
      allow delete: if isAdmin() && adminEmail != "phandu8899@gmail.com";
      allow update: if false;
    }

    match /checkins/{userId} {
      // Users can read their own check-in, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own check-in once
      allow create: if isOwner(userId) && isValidCheckIn(userId);
      
      // Check-ins are immutable once created
      allow update: if false;
      allow delete: if false;
    }
  }
}
