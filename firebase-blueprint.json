{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Admin user email",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedBy": { "type": "string" },
        "timestamp": { "type": "timestamp" }
      },
      "required": ["email", "addedBy", "timestamp"]
    },
    "CheckIn": {
      "title": "CheckIn",
      "description": "A student's check-in record for the event.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The Google Auth UID of the user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user."
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the student."
        },
        "contactInfo": {
          "type": "string",
          "description": "Thông tin liên hệ (SĐT/Zalo)."
        },
        "timestamp": {
          "type": "timestamp",
          "description": "The time the check-in occurred."
        },
        "latitude": {
          "type": "number",
          "description": "Latitude of the user when checking in."
        },
        "longitude": {
          "type": "number",
          "description": "Longitude of the user when checking in."
        }
      },
      "required": ["uid", "email", "fullName", "contactInfo", "timestamp", "latitude", "longitude"]
    }
  },
  "firestore": {
    "/admins/{email}": {
      "schema": "Admin",
      "description": "Stores admin emails."
    },
    "/checkins/{uid}": {
      "schema": "CheckIn",
      "description": "Stores check-in records, keyed by the user's UID to ensure one check-in per account."
    }
  }
}
